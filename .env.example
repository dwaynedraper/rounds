# Copy this file to .env.local and fill in real values there.
# .env.local is gitignored — never commit real secrets, never paste them
# into chat/PR descriptions/issues either.

# ============================================================
# REQUIRED RIGHT NOW — nothing else works without this one.
# ============================================================

# Neon Postgres connection string (HTTP driver, region us-east-1 — plan
# §1 item 13). Get this from the Neon dashboard for the "rounds" project.
DATABASE_URL="postgresql://user:password@ep-xxxx-pooler.c-2.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require"

# ============================================================
# NOT NEEDED YET — nothing reads these until Phase 2 (CMS auth).
# Left here now so the shape of the file doesn't change later;
# blank/placeholder values are fine until then.
# ============================================================

# Better Auth (Phase 2 — CMS login only; survey stays loginless)
BETTER_AUTH_SECRET=""
BETTER_AUTH_URL="http://localhost:3000"

# Resend (Phase 2 — magic-link email)
RESEND_API_KEY=""
AUTH_EMAIL_FROM="Rounds <onboarding@resend.dev>"

# Feature flags — default OFF (plan S9). Config, not code, to turn on.
TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""
STORE_SLUG_MODE="off"
